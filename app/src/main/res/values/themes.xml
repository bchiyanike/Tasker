<?xml version="1.0" encoding="utf-8"?>
<!-- File: app/src/main/res/values/themes.xml -->
<resources>
    <!-- SplashScreen theme (REQUIRED for Android 12+) -->
    <style name="Theme.Lionico.Template.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <!-- Theme applied AFTER splash -->
        <item name="postSplashScreenTheme">@style/Theme.Lionico.Template</item>
    </style>

    <!-- Main app theme -->
    <style name="Theme.Lionico.Template" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>
</resources>